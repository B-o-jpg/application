<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0"
            style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #fff5f1 0%, #ffe6d5 100%);"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.controllers.POSController">

    <!-- Header -->
    <VBox prefHeight="80.0" prefWidth="1200.0"
          style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">
        <padding>
            <Insets top="10" bottom="10" left="20" right="20"/>
        </padding>

        <Label text="Terminal 01 - Restaurant POS System" textFill="#d4724a">
            <font>
                <Font size="24"/>
            </font>
        </Label>

        <Label fx:id="timeLabel" text="TIME" textFill="#666"/>
    </VBox>

    <HBox layoutY="80" spacing="20">
        <padding>
            <Insets top="20" bottom="20" left="20" right="20"/>
        </padding>

        <!-- LEFT SIDE MENU -->
        <VBox spacing="20">

            <!-- DINNER -->
            <VBox spacing="10" style="-fx-background-color:white; -fx-padding:15; -fx-border-color:#e0b5a0;">
                <Label text="DINNER SELECTION"/>
                <HBox spacing="10">
                    <CheckBox fx:id="steak" text="Steak (M150)"/>
                    <CheckBox fx:id="roastedChicken" text="Roasted Chicken (M120)"/>
                    <CheckBox fx:id="creamyPasta" text="Creamy Pasta (M95)"/>
                </HBox>

                <HBox spacing="10">
                    <CheckBox fx:id="lambChops" text="Lamb Chops (M180)"/>
                    <CheckBox fx:id="grilledFish" text="Grilled Fish (M140)"/>
                    <CheckBox fx:id="beefBurger" text="Double Beef Burger (M110)"/>
                </HBox>
            </VBox>

            <!-- DESSERTS (Single Selection) -->
            <VBox prefHeight="200.0" prefWidth="350.0" spacing="10.0"
                  style="-fx-border-color: #e0b5a0; -fx-border-radius: 10; -fx-background-color: white; -fx-padding: 15;">
                <fx:define>
                    <ToggleGroup fx:id="dessertGroup"/>
                </fx:define>

                <Label text="DESSERT (Single Selection)" textFill="#d4724a"/>

                <RadioButton text="Chocolate Cake (M45)" fx:id="chocolateCake" toggleGroup="$dessertGroup"/>
                <RadioButton text="Vanilla Ice Cream (M35)" fx:id="vanillaIceCream" toggleGroup="$dessertGroup"/>
                <RadioButton text="Apple Pie (M40)" fx:id="applePie" toggleGroup="$dessertGroup"/>
                <RadioButton text="Malva Pudding (M50)" fx:id="malvaPudding" toggleGroup="$dessertGroup"/>
            </VBox>

            <!-- DRINKS -->
            <VBox spacing="10" style="-fx-background-color:white; -fx-padding:15;">
                <Label text="DRINKS"/>
                <ComboBox fx:id="drinkCombo" prefWidth="250"/>
            </VBox>

        </VBox>

        <!-- RIGHT SIDE SUMMARY -->
        <VBox spacing="15" style="-fx-background-color:#333; -fx-padding:20;" prefWidth="350">

            <Label text="ORDER SUMMARY" textFill="white"/>

            <HBox alignment="CENTER_RIGHT">
                <Label text="SUBTOTAL:" textFill="white"/>
                <Label fx:id="subtotalLabel" text="M0.00" textFill="white"/>
            </HBox>

            <HBox alignment="CENTER_RIGHT">
                <Label text="TOTAL:" textFill="white"/>
                <Label fx:id="totalLabel" text="M0.00" textFill="#d4724a"/>
            </HBox>

            <Label text="Cash Paid" textFill="white"/>
            <TextField fx:id="cashPaidField"/>

            <Label text="Change" textFill="white"/>
            <Label fx:id="changeLabel" text="M0.00" textFill="#00ff88"/>

            <Label fx:id="errorLabel" textFill="white"/>

            <Button fx:id="saveButton" text="SAVE RECEIPT" onAction="#handleSave"/>
            <Button fx:id="resetButton" text="RESET" onAction="#handleReset"/>
            <Button fx:id="exitButton" text="EXIT" onAction="#handleExit"/>

        </VBox>

    </HBox>

</AnchorPane>