<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: linear-gradient(135deg, #fff5f1 0%, #ffe6d5 100%);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.controllers.LoginController">
    <VBox alignment="CENTER" layoutX="200.0" layoutY="150.0" prefHeight="400.0" prefWidth="600.0" spacing="20.0" style="-fx-background-color: white; -fx-border-radius: 20; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 20, 0, 0, 10);">
        <padding>
            <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
        </padding>

        <!-- Logo / Title -->
        <Label alignment="CENTER" text="🍽️ RESTAURANT POS" textFill="#d4724a" wrapText="true">
            <font>
                <Font name="System Bold" size="36.0" />
            </font>
        </Label>

        <Label alignment="CENTER" text="Welcome to the Point of Sale System" textFill="#666666" wrapText="true">
            <font>
                <Font size="14.0" />
            </font>
        </Label>

        <!-- Username Field -->
        <Label text="Username" textFill="#333333">
            <font>
                <Font size="12.0" />
            </font>
        </Label>
        <TextField fx:id="usernameField" prefHeight="45.0" prefWidth="500.0" promptText="Enter your username" style="-fx-padding: 10; -fx-font-size: 14; -fx-border-color: #ddd; -fx-border-radius: 5;">
        </TextField>

        <!-- Password Field -->
        <Label text="Password" textFill="#333333">
            <font>
                <Font size="12.0" />
            </font>
        </Label>
        <PasswordField fx:id="passwordField" prefHeight="45.0" prefWidth="500.0" promptText="Enter your password" style="-fx-padding: 10; -fx-font-size: 14; -fx-border-color: #ddd; -fx-border-radius: 5;">
        </PasswordField>

        <!-- Error Label -->
        <Label fx:id="errorLabel" prefHeight="20.0" prefWidth="500.0" textFill="#c41e3a" wrapText="true">
            <font>
                <Font size="11.0" />
            </font>
        </Label>

        <!-- Buttons -->
        <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLogin" prefHeight="45.0" prefWidth="500.0" style="-fx-font-size: 14; -fx-padding: 10; -fx-background-color: #d4724a; -fx-text-fill: white; -fx-border-radius: 5; -fx-font-weight: bold;" text="Login to System">
            <font>
                <Font size="14.0" />
            </font>
        </Button>

        <Button fx:id="exitButton" mnemonicParsing="false" onAction="#handleExit" prefHeight="45.0" prefWidth="500.0" style="-fx-font-size: 14; -fx-padding: 10; -fx-background-color: #999999; -fx-text-fill: white; -fx-border-radius: 5; -fx-font-weight: bold;" text="Exit">
            <font>
                <Font size="14.0" />
            </font>
        </Button>
    </VBox>
</AnchorPane>
